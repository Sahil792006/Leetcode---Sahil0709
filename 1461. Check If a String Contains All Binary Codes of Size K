class Solution {
    public boolean hasAllCodes(String s, int k) {
        int need = 1 << k;
        HashSet<String> seen = new HashSet<>();
        for(int i = 0 ; i < s.length()-k+1; i++){
            seen.add(s.substring(i,i+k));
            if(seen.size() == need){
                return true;
            }
        }
        return false;
    }
}
